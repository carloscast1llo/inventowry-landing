  <!-- Scripts -->
  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
    menu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => menu?.classList.add('hidden'));
    });

    const btnMonthly = document.getElementById('btn-monthly');
    const btnYearly = document.getElementById('btn-yearly');
    const monthlyEls = document.querySelectorAll('.price-monthly');
    const yearlyEls = document.querySelectorAll('.price-yearly');

    function setMonthly() {
      btnMonthly?.classList.add('bg-primary-600', 'text-white', 'shadow-sm');
      btnMonthly?.classList.remove('text-zinc-500');
      btnYearly?.classList.remove('bg-primary-600', 'text-white', 'shadow-sm');
      btnYearly?.classList.add('text-zinc-500');
      monthlyEls.forEach(el => el.classList.remove('hidden'));
      yearlyEls.forEach(el => el.classList.add('hidden'));
    }

    function setYearly() {
      btnYearly?.classList.add('bg-primary-600', 'text-white', 'shadow-sm');
      btnYearly?.classList.remove('text-zinc-500');
      btnMonthly?.classList.remove('bg-primary-600', 'text-white', 'shadow-sm');
      btnMonthly?.classList.add('text-zinc-500');
      yearlyEls.forEach(el => el.classList.remove('hidden'));
      monthlyEls.forEach(el => el.classList.add('hidden'));
    }

    btnMonthly?.addEventListener('click', setMonthly);
    btnYearly?.addEventListener('click', setYearly);

    // Nav scroll: transparent on hero, solid on scroll
    const nav = document.getElementById('main-nav');
    const logoDark = nav?.querySelector('.nav-logo-dark');
    const logoLight = nav?.querySelector('.nav-logo-light');
    const navLinks = nav?.querySelectorAll('.nav-link');
    const navCta = nav?.querySelector('.nav-cta');
    const mobileBtn = nav?.querySelector('#mobile-menu-btn');
    const mobileMenu = nav?.querySelector('#mobile-menu');

    const mobileMenuInner = mobileMenu?.querySelector('div');

    function isOverDark() {
      const navMid = (nav?.offsetHeight || 60) / 2;
      const darkSections = document.querySelectorAll('[data-dark-section]');
      for (const s of darkSections) {
        const rect = s.getBoundingClientRect();
        if (rect.top <= navMid && rect.bottom >= navMid) return true;
      }
      return false;
    }

    function updateNav() {
      const dark = isOverDark();

      // Logo
      if (dark) {
        logoDark?.classList.remove('hidden');
        logoLight?.classList.add('hidden');
      } else {
        logoDark?.classList.add('hidden');
        logoLight?.classList.remove('hidden');
      }

      // Links
      navLinks?.forEach(l => {
        l.classList.toggle('text-white/75', dark);
        l.classList.toggle('hover:text-white', dark);
        l.classList.toggle('text-zinc-600', !dark);
        l.classList.toggle('hover:text-blue-600', !dark);
      });

      // CTA
      navCta?.classList.toggle('bg-white/15', dark);
      navCta?.classList.toggle('border-white/20', dark);
      navCta?.classList.toggle('hover:bg-white/25', dark);
      navCta?.classList.toggle('bg-gradient-to-r', !dark);
      navCta?.classList.toggle('from-blue-600', !dark);
      navCta?.classList.toggle('to-blue-500', !dark);
      navCta?.classList.toggle('border-transparent', !dark);
      navCta?.classList.toggle('shadow-md', !dark);
      navCta?.classList.toggle('shadow-blue-600/20', !dark);

      // Mobile btn
      mobileBtn?.classList.toggle('text-white/70', dark);
      mobileBtn?.classList.toggle('hover:bg-white/10', dark);
      mobileBtn?.classList.toggle('text-zinc-600', !dark);
      mobileBtn?.classList.toggle('hover:bg-zinc-100', !dark);

      // Mobile menu
      if (mobileMenuInner) {
        mobileMenuInner.classList.toggle('bg-primary-900/95', dark);
        mobileMenuInner.classList.toggle('border-white/10', dark);
        mobileMenuInner.classList.toggle('bg-white/95', !dark);
        mobileMenuInner.classList.toggle('border-zinc-200/60', !dark);
        mobileMenuInner.querySelectorAll('a').forEach(a => {
          a.classList.toggle('text-white/80', dark);
          a.classList.toggle('hover:bg-white/10', dark);
          a.classList.toggle('hover:text-white', dark);
          a.classList.toggle('text-zinc-600', !dark);
          a.classList.toggle('hover:bg-blue-50', !dark);
          a.classList.toggle('hover:text-blue-700', !dark);
        });
        const hr = mobileMenuInner.querySelector('hr');
        if (hr) {
          hr.classList.toggle('border-white/10', dark);
          hr.classList.toggle('border-zinc-200', !dark);
        }
      }
    }

    window.addEventListener('scroll', updateNav, { passive: true });
    updateNav();
  </script>
</Layout>
