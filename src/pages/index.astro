---
import Layout from '../layouts/Layout.astro';

const features = [
  {
    icon: 'M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25',
    title: 'Inventario Completo',
    description: 'Registra automáticamente CPU, memoria, almacenamiento, software instalado y más de cada dispositivo.',
    gradient: 'from-blue-500 to-blue-600',
    bg: 'bg-blue-50',
    iconColor: 'text-blue-600',
    accent: 'blue',
  },
  {
    icon: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z',
    title: 'Monitorización en Tiempo Real',
    description: 'Alertas configurables, métricas de rendimiento y estado online/offline al instante.',
    gradient: 'from-amber-500 to-orange-500',
    bg: 'bg-amber-50',
    iconColor: 'text-amber-600',
    accent: 'amber',
  },
  {
    icon: 'M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z',
    title: 'Comandos Remotos',
    description: 'Ejecuta Shell y PowerShell en cualquier dispositivo. Resultados en tiempo real con historial completo.',
    gradient: 'from-emerald-500 to-emerald-600',
    bg: 'bg-emerald-50',
    iconColor: 'text-emerald-600',
    accent: 'emerald',
  },
  {
    icon: 'M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z',
    title: 'Enrollment Masivo',
    description: 'Genera tokens y scripts de instalación para registrar cientos de dispositivos en minutos.',
    gradient: 'from-violet-500 to-purple-600',
    bg: 'bg-violet-50',
    iconColor: 'text-violet-600',
    accent: 'violet',
  },
  {
    icon: 'M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z',
    title: 'Multi-Tenant',
    description: 'Equipos aislados con roles (Owner, Admin, Manager, Member) y permisos granulares.',
    gradient: 'from-rose-500 to-pink-600',
    bg: 'bg-rose-50',
    iconColor: 'text-rose-600',
    accent: 'rose',
  },
  {
    icon: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
    title: 'Seguridad Avanzada',
    description: 'JWT RS256, autenticación de dos factores, firma criptográfica de binarios y RBAC completo.',
    gradient: 'from-cyan-500 to-sky-600',
    bg: 'bg-cyan-50',
    iconColor: 'text-cyan-600',
    accent: 'cyan',
  },
];

const plans = [
  {
    name: 'Starter',
    monthly: '29',
    yearly: '23',
    devices: '10',
    overage: '2,50',
    features: ['10 dispositivos incluidos', 'Monitorización en tiempo real', 'Comandos remotos', 'Alertas de rendimiento', 'Soporte por email'],
    highlighted: false,
  },
  {
    name: 'Professional',
    monthly: '99',
    yearly: '79',
    devices: '50',
    overage: '2,00',
    features: ['50 dispositivos incluidos', 'Todo de Starter', 'Enrollment masivo', 'Gestión de equipos', 'Soporte prioritario'],
    highlighted: true,
  },
  {
    name: 'Enterprise',
    monthly: '159',
    yearly: '127',
    devices: '100',
    overage: '1,50',
    features: ['100 dispositivos incluidos', 'Todo de Professional', 'Actualizaciones daemon', 'API completa', 'Soporte dedicado'],
    highlighted: false,
  },
];

const faqs = [
  { q: '¿Cuánto dura la prueba gratuita?', a: '14 días completos con acceso a todas las funcionalidades. No se requiere tarjeta de crédito para empezar.' },
  { q: '¿Qué plataformas son compatibles?', a: 'Windows, macOS y Linux en arquitecturas x64, ARM64 e i386. El agente se instala con un solo comando.' },
  { q: '¿Cómo se instala el agente en los dispositivos?', a: 'Generamos un script de instalación único para tu equipo. Solo tienes que ejecutar un comando en el dispositivo y se registra automáticamente.' },
  { q: '¿Mis datos están seguros?', a: 'Toda la comunicación está cifrada con JWT RS256. Los binarios del agente están firmados criptográficamente y ofrecemos autenticación de dos factores.' },
  { q: '¿Puedo cambiar de plan en cualquier momento?', a: 'Sí, puedes subir o bajar de plan cuando quieras. El cambio se aplica inmediatamente y se prorratea la diferencia.' },
  { q: '¿Qué pasa si supero el límite de dispositivos de mi plan?', a: 'Se cobra un precio por dispositivo extra según tu plan. Sin cortes de servicio ni sorpresas.' },
];

const stats = [
  { value: '3', label: 'Plataformas soportadas', icon: 'M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25' },
  { value: '24/7', label: 'Monitorización continua', icon: 'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z' },
  { value: '<5min', label: 'Tiempo de despliegue', icon: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z' },
  { value: '100%', label: 'Comunicación cifrada', icon: 'M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z' },
];
---

<Layout>
  <!-- Navbar -->
  <nav id="main-nav" class="fixed top-0 z-50 w-full backdrop-blur-sm">
    <div class="relative mx-auto flex max-w-7xl items-center px-6 py-5 lg:px-8">
      <!-- Logo left -->
      <a href="/" class="relative z-10 flex items-center gap-2">
        <img src="/images/logo_inventowry-dark.svg" alt="Inventowry" class="nav-logo-dark h-10 sm:h-11 transition-all duration-300" />
        <img src="/images/logo_inventowry.svg" alt="Inventowry" class="nav-logo-light h-10 sm:h-11 hidden transition-all duration-300" />
      </a>

      <!-- Links centered absolutely -->
      <div class="absolute inset-0 hidden items-center justify-center gap-9 md:flex">
        <a href="#features" class="nav-link text-[15px] font-semibold tracking-wide text-white/75 transition-colors hover:text-white">Funcionalidades</a>
        <a href="#how-it-works" class="nav-link text-[15px] font-semibold tracking-wide text-white/75 transition-colors hover:text-white">Cómo funciona</a>
        <a href="#pricing" class="nav-link text-[15px] font-semibold tracking-wide text-white/75 transition-colors hover:text-white">Precios</a>
        <a href="#faq" class="nav-link text-[15px] font-semibold tracking-wide text-white/75 transition-colors hover:text-white">FAQ</a>
      </div>

      <!-- CTA right -->
      <div class="relative z-10 ml-auto flex items-center gap-5">
        <a href="https://app.inventowry.com/login" class="nav-link hidden text-[15px] font-semibold tracking-wide text-white/75 transition-colors hover:text-white sm:block">
          Iniciar sesión
        </a>
        <a href="https://app.inventowry.com/register" class="nav-cta rounded-lg bg-white/15 backdrop-blur-sm border border-white/20 px-6 py-2.5 text-[15px] font-semibold text-white transition-all hover:bg-white/25 hover:-translate-y-0.5">
          Empezar gratis
        </a>
        <button id="mobile-menu-btn" class="flex items-center justify-center rounded-lg p-2 text-white/70 transition hover:bg-white/10 md:hidden" aria-label="Menú">
          <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
        </button>
      </div>
    </div>

    <div id="mobile-menu" class="hidden md:hidden">
      <div class="flex flex-col gap-1 px-6 py-4 backdrop-blur-xl bg-primary-900/95 border-t border-white/10">
        <a href="#features" class="rounded-lg px-3 py-2.5 text-sm font-medium text-white/80 transition hover:bg-white/10 hover:text-white">Funcionalidades</a>
        <a href="#how-it-works" class="rounded-lg px-3 py-2.5 text-sm font-medium text-white/80 transition hover:bg-white/10 hover:text-white">Cómo funciona</a>
        <a href="#pricing" class="rounded-lg px-3 py-2.5 text-sm font-medium text-white/80 transition hover:bg-white/10 hover:text-white">Precios</a>
        <a href="#faq" class="rounded-lg px-3 py-2.5 text-sm font-medium text-white/80 transition hover:bg-white/10 hover:text-white">FAQ</a>
        <hr class="my-2 border-white/10" />
        <a href="https://app.inventowry.com/login" class="rounded-lg px-3 py-2.5 text-sm font-medium text-white/80 transition hover:bg-white/10 hover:text-white">Iniciar sesión</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section data-dark-section class="relative overflow-hidden pt-36 pb-24 sm:pt-44 sm:pb-32 lg:pt-48 lg:pb-36">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0" style="background: linear-gradient(to bottom, #1e293b, #0f172a 50%, #0c1222)"></div>
      <div class="absolute inset-0" style="background-image: radial-gradient(rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 24px 24px;"></div>
      <div class="absolute top-[-100px] left-[20%] h-[600px] w-[600px] rounded-full bg-blue-500/20 blur-[150px]"></div>
      <div class="absolute top-[20%] right-[0%] h-[400px] w-[600px] rounded-full bg-indigo-500/15 blur-[150px]"></div>
      <div class="absolute bottom-[0%] left-[40%] h-[300px] w-[400px] rounded-full bg-sky-500/10 blur-[120px]"></div>
    </div>

    <!-- Floating glass cards -->
    <div class="absolute top-36 left-[6%] hidden lg:block animate-float">
      <div class="rounded-xl border border-white/15 bg-white/10 backdrop-blur-md px-4 py-3 shadow-lg">
        <div class="flex items-center gap-2.5">
          <div class="flex size-8 items-center justify-center rounded-lg bg-emerald-400/20">
            <svg class="size-4 text-emerald-300" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
          </div>
          <div>
            <p class="text-[10px] font-medium text-white/50">Estado</p>
            <p class="text-xs font-bold text-emerald-300">231 Online</p>
          </div>
        </div>
      </div>
    </div>
    <div class="absolute top-52 right-[7%] hidden lg:block animate-float-slow">
      <div class="rounded-xl border border-white/15 bg-white/10 backdrop-blur-md px-4 py-3 shadow-lg">
        <div class="flex items-center gap-2.5">
          <div class="flex size-8 items-center justify-center rounded-lg bg-violet-400/20">
            <svg class="size-4 text-violet-300" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
          </div>
          <div>
            <p class="text-[10px] font-medium text-white/50">Seguridad</p>
            <p class="text-xs font-bold text-violet-300">JWT RS256</p>
          </div>
        </div>
      </div>
    </div>
    <div class="absolute bottom-[38%] left-[4%] hidden lg:block animate-float" style="animation-delay: 1.5s;">
      <div class="rounded-xl border border-white/15 bg-white/10 backdrop-blur-md px-4 py-3 shadow-lg">
        <div class="flex items-center gap-2.5">
          <div class="flex size-8 items-center justify-center rounded-lg bg-cyan-400/20">
            <svg class="size-4 text-cyan-300" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3" /></svg>
          </div>
          <div>
            <p class="text-[10px] font-medium text-white/50">Terminal</p>
            <p class="text-xs font-bold text-cyan-300">Remoto</p>
          </div>
        </div>
      </div>
    </div>
    <div class="absolute bottom-[42%] right-[5%] hidden lg:block animate-float-slow" style="animation-delay: 2.5s;">
      <div class="rounded-xl border border-white/15 bg-white/10 backdrop-blur-md px-4 py-3 shadow-lg">
        <div class="flex items-center gap-2.5">
          <div class="flex size-8 items-center justify-center rounded-lg bg-amber-400/20">
            <svg class="size-4 text-amber-300" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>
          </div>
          <div>
            <p class="text-[10px] font-medium text-white/50">Alertas</p>
            <p class="text-xs font-bold text-amber-300">3 activas</p>
          </div>
        </div>
      </div>
    </div>

    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-4xl text-center">
        <div class="animate-fade-up inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-2 text-sm font-medium text-white/90 backdrop-blur-sm mb-10">
          <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>
          Compatible con Windows, macOS y Linux
        </div>

        <h1 class="animate-fade-up animate-delay-100 text-5xl font-black tracking-tight text-white sm:text-6xl lg:text-7xl leading-[1.1] text-glow">
          Gestiona todos tus<br class="hidden sm:block" />
          <span class="hero-gradient-text">dispositivos</span> desde<br class="hidden sm:block" />
          un solo lugar
        </h1>

        <p class="animate-fade-up animate-delay-200 mx-auto mt-8 max-w-2xl text-lg leading-relaxed text-white/70 sm:text-xl">
          Monitoriza, controla y protege tu parque tecnológico empresarial. Inventario automático, alertas inteligentes y comandos remotos en una plataforma unificada.
        </p>

        <div class="animate-fade-up animate-delay-300 mt-12 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href="https://app.inventowry.com/register" class="group w-full rounded-xl bg-white px-8 py-4 text-base font-semibold text-primary-700 shadow-xl shadow-black/10 transition-all hover:bg-primary-50 hover:-translate-y-0.5 sm:w-auto">
            Empieza tu prueba gratuita
            <svg class="ml-2 inline-block size-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
          <a href="#how-it-works" class="w-full rounded-xl border border-white/25 bg-white/10 px-8 py-4 text-base font-semibold text-white backdrop-blur-sm transition-all hover:bg-white/20 hover:-translate-y-0.5 sm:w-auto">
            Ver cómo funciona
          </a>
        </div>

        <p class="animate-fade-up animate-delay-400 mt-5 text-sm text-primary-200/70">14 días gratis &middot; Sin tarjeta de crédito</p>
      </div>

      <!-- Hero Dashboard Mockup -->
      <div class="animate-fade-up animate-delay-500 relative mx-auto mt-20 max-w-5xl group/mockup">
        <!-- Glow behind mockup -->
        <div class="absolute -inset-4 rounded-3xl bg-gradient-to-r from-primary-400/20 via-violet-400/20 to-cyan-400/20 blur-2xl opacity-60 group-hover/mockup:opacity-100 transition-opacity duration-700"></div>
        <div class="relative animate-float-slow rounded-2xl border border-white/15 bg-white p-1.5 shadow-2xl shadow-black/30 ring-1 ring-white/10">
          <div class="flex items-center gap-2 rounded-t-xl bg-zinc-100 px-4 py-2.5">
            <div class="flex gap-1.5">
              <div class="size-2.5 rounded-full bg-red-400"></div>
              <div class="size-2.5 rounded-full bg-amber-400"></div>
              <div class="size-2.5 rounded-full bg-emerald-400"></div>
            </div>
            <div class="mx-auto flex items-center gap-2 rounded-md bg-white/60 px-3 py-1">
              <svg class="size-3 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75" /></svg>
              <span class="text-[11px] text-zinc-500">app.inventowry.com/dashboard</span>
            </div>
          </div>

          <div class="rounded-b-xl bg-zinc-50 p-3 sm:p-5">
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 sm:gap-3 mb-3 sm:mb-5">
              <div class="rounded-xl border border-zinc-200/80 bg-white p-2.5 sm:p-3.5">
                <p class="text-[9px] sm:text-[10px] font-medium text-zinc-400 uppercase tracking-wider">Dispositivos</p>
                <p class="mt-0.5 sm:mt-1 text-lg sm:text-xl font-bold text-zinc-900">247</p>
                <div class="mt-1 flex items-center gap-1">
                  <span class="text-[9px] sm:text-[10px] font-semibold text-emerald-500">+12%</span>
                  <svg class="size-2.5 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.293 9.707a1 1 0 010-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L11 7.414V15a1 1 0 11-2 0V7.414L6.707 9.707a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg>
                </div>
              </div>
              <div class="rounded-xl border border-zinc-200/80 bg-white p-2.5 sm:p-3.5">
                <p class="text-[9px] sm:text-[10px] font-medium text-zinc-400 uppercase tracking-wider">Online</p>
                <p class="mt-0.5 sm:mt-1 text-lg sm:text-xl font-bold text-emerald-600">231</p>
                <div class="mt-1 h-1.5 w-full rounded-full bg-zinc-100">
                  <div class="h-1.5 rounded-full bg-emerald-500" style="width: 93%"></div>
                </div>
              </div>
              <div class="rounded-xl border border-zinc-200/80 bg-white p-2.5 sm:p-3.5">
                <p class="text-[9px] sm:text-[10px] font-medium text-zinc-400 uppercase tracking-wider">Alertas</p>
                <p class="mt-0.5 sm:mt-1 text-lg sm:text-xl font-bold text-amber-600">3</p>
                <div class="mt-1 flex gap-1">
                  <span class="inline-flex rounded bg-amber-100 px-1.5 py-0.5 text-[8px] sm:text-[9px] font-semibold text-amber-700">Warning</span>
                </div>
              </div>
              <div class="rounded-xl border border-zinc-200/80 bg-white p-2.5 sm:p-3.5">
                <p class="text-[9px] sm:text-[10px] font-medium text-zinc-400 uppercase tracking-wider">Uptime</p>
                <p class="mt-0.5 sm:mt-1 text-lg sm:text-xl font-bold text-primary-600">99.8%</p>
                <div class="mt-1 flex items-center gap-1">
                  <span class="text-[9px] sm:text-[10px] font-semibold text-emerald-500">+0.2%</span>
                </div>
              </div>
            </div>

            <div class="hidden sm:grid grid-cols-5 gap-3">
              <div class="col-span-3 rounded-xl border border-zinc-200/80 bg-white">
                <div class="border-b border-zinc-100 px-4 py-2.5">
                  <p class="text-[11px] font-semibold text-zinc-700">Dispositivos recientes</p>
                </div>
