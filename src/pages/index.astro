---
import Layout from '../layouts/Layout.astro';

const features = [
  {
    icon: 'M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25',
    title: 'Inventario Completo',
    description: 'Registra automáticamente CPU, memoria, almacenamiento, software instalado y más de cada dispositivo.',
    color: 'blue',
    bg: 'bg-blue-50 dark:bg-blue-950/40',
    iconColor: 'text-blue-600 dark:text-blue-400',
    borderHover: 'hover:border-blue-200 dark:hover:border-blue-800',
  },
  {
    icon: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z',
    title: 'Monitorización en Tiempo Real',
    description: 'Alertas configurables, métricas de rendimiento y estado online/offline al instante.',
    color: 'amber',
    bg: 'bg-amber-50 dark:bg-amber-950/40',
    iconColor: 'text-amber-600 dark:text-amber-400',
    borderHover: 'hover:border-amber-200 dark:hover:border-amber-800',
  },
  {
    icon: 'M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z',
    title: 'Comandos Remotos',
    description: 'Ejecuta Shell y PowerShell en cualquier dispositivo. Resultados en tiempo real con historial completo.',
    color: 'emerald',
    bg: 'bg-emerald-50 dark:bg-emerald-950/40',
    iconColor: 'text-emerald-600 dark:text-emerald-400',
    borderHover: 'hover:border-emerald-200 dark:hover:border-emerald-800',
  },
  {
    icon: 'M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z',
    title: 'Enrollment Masivo',
    description: 'Genera tokens y scripts de instalación para registrar cientos de dispositivos en minutos.',
    color: 'violet',
    bg: 'bg-violet-50 dark:bg-violet-950/40',
    iconColor: 'text-violet-600 dark:text-violet-400',
    borderHover: 'hover:border-violet-200 dark:hover:border-violet-800',
  },
  {
    icon: 'M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z',
    title: 'Multi-Tenant',
    description: 'Equipos aislados con roles (Owner, Admin, Manager, Member) y permisos granulares.',
    color: 'rose',
    bg: 'bg-rose-50 dark:bg-rose-950/40',
    iconColor: 'text-rose-600 dark:text-rose-400',
    borderHover: 'hover:border-rose-200 dark:hover:border-rose-800',
  },
  {
    icon: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
    title: 'Seguridad Avanzada',
    description: 'JWT RS256, autenticación de dos factores, firma criptográfica de binarios y RBAC completo.',
    color: 'cyan',
    bg: 'bg-cyan-50 dark:bg-cyan-950/40',
    iconColor: 'text-cyan-600 dark:text-cyan-400',
    borderHover: 'hover:border-cyan-200 dark:hover:border-cyan-800',
  },
];

const plans = [
  {
    name: 'Starter',
    price: '29',
    devices: '10',
    overage: '2,50',
    features: ['10 dispositivos incluidos', 'Monitorización en tiempo real', 'Comandos remotos', 'Alertas de rendimiento', 'Soporte por email'],
    highlighted: false,
  },
  {
    name: 'Professional',
    price: '99',
    devices: '50',
    overage: '2,00',
    features: ['50 dispositivos incluidos', 'Todo de Starter', 'Enrollment masivo', 'Gestión de equipos', 'Soporte prioritario'],
    highlighted: true,
  },
  {
    name: 'Enterprise',
    price: '159',
    devices: '100',
    overage: '1,50',
    features: ['100 dispositivos incluidos', 'Todo de Professional', 'Actualizaciones daemon', 'API completa', 'Soporte dedicado'],
    highlighted: false,
  },
];

const stats = [
  { value: '3', label: 'Plataformas soportadas', icon: 'M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25' },
  { value: '24/7', label: 'Monitorización continua', icon: 'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z' },
  { value: '<5min', label: 'Tiempo de despliegue', icon: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z' },
  { value: '100%', label: 'Comunicación cifrada', icon: 'M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z' },
];
---

<Layout>
  <!-- Navbar -->
  <nav class="fixed top-0 z-50 w-full border-b border-zinc-200/60 bg-white/70 backdrop-blur-xl dark:border-zinc-800/60 dark:bg-zinc-950/70">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-8">
      <a href="/" class="flex items-center gap-2">
        <img src="/images/logo_inventowry.svg" alt="Inventowry" class="h-8 dark:hidden" />
        <img src="/images/logo_inventowry-dark.svg" alt="Inventowry" class="hidden h-8 dark:block" />
      </a>

      <div class="hidden items-center gap-8 text-sm font-medium text-zinc-500 dark:text-zinc-400 md:flex">
        <a href="#features" class="transition-colors hover:text-zinc-900 dark:hover:text-zinc-100">Funcionalidades</a>
        <a href="#how-it-works" class="transition-colors hover:text-zinc-900 dark:hover:text-zinc-100">Cómo funciona</a>
        <a href="#pricing" class="transition-colors hover:text-zinc-900 dark:hover:text-zinc-100">Precios</a>
      </div>

      <div class="flex items-center gap-4">
        <a href="https://app.inventowry.com/login" class="hidden text-sm font-medium text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100 sm:block">
          Iniciar sesión
        </a>
        <a href="https://app.inventowry.com/register" class="rounded-lg bg-primary-600 px-4 py-2 text-sm font-semibold text-white shadow-sm shadow-primary-600/20 transition-all hover:bg-primary-500 hover:shadow-md hover:shadow-primary-600/25">
          Empezar gratis
        </a>

        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="flex items-center justify-center rounded-lg p-2 text-zinc-500 transition hover:bg-zinc-100 dark:hover:bg-zinc-800 md:hidden" aria-label="Menú">
          <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden border-t border-zinc-200/60 bg-white/95 backdrop-blur-xl dark:border-zinc-800/60 dark:bg-zinc-950/95 md:hidden">
      <div class="flex flex-col gap-1 px-6 py-4">
        <a href="#features" class="rounded-lg px-3 py-2.5 text-sm font-medium text-zinc-600 transition hover:bg-zinc-100 dark:text-zinc-400 dark:hover:bg-zinc-800">Funcionalidades</a>
        <a href="#how-it-works" class="rounded-lg px-3 py-2.5 text-sm font-medium text-zinc-600 transition hover:bg-zinc-100 dark:text-zinc-400 dark:hover:bg-zinc-800">Cómo funciona</a>
        <a href="#pricing" class="rounded-lg px-3 py-2.5 text-sm font-medium text-zinc-600 transition hover:bg-zinc-100 dark:text-zinc-400 dark:hover:bg-zinc-800">Precios</a>
        <hr class="my-2 border-zinc-200 dark:border-zinc-800" />
        <a href="https://app.inventowry.com/login" class="rounded-lg px-3 py-2.5 text-sm font-medium text-zinc-600 transition hover:bg-zinc-100 dark:text-zinc-400 dark:hover:bg-zinc-800">Iniciar sesión</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative overflow-hidden pt-36 pb-24 sm:pt-44 sm:pb-32 lg:pt-48 lg:pb-36">
    <!-- Background -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-br from-primary-50 via-white to-violet-50/50 dark:from-primary-950/30 dark:via-zinc-950 dark:to-violet-950/20"></div>
      <div class="absolute top-[-200px] left-1/2 -translate-x-1/2 h-[800px] w-[1200px] rounded-full bg-gradient-to-r from-primary-400/15 via-violet-400/10 to-cyan-400/15 blur-3xl dark:from-primary-600/10 dark:via-violet-600/5 dark:to-cyan-600/10"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-zinc-300 to-transparent dark:via-zinc-700"></div>
    </div>

    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-4xl text-center">
        <div class="animate-fade-up inline-flex items-center gap-2 rounded-full border border-primary-200/80 bg-white/80 px-4 py-2 text-sm font-medium text-primary-700 shadow-sm backdrop-blur-sm dark:border-primary-800/50 dark:bg-zinc-900/80 dark:text-primary-300 mb-10">
          <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>
          Compatible con Windows, macOS y Linux
        </div>

        <h1 class="animate-fade-up animate-delay-100 text-5xl font-black tracking-tight sm:text-6xl lg:text-7xl leading-[1.1]">
          Gestiona todos tus dispositivos
          <span class="bg-gradient-to-r from-primary-600 via-primary-500 to-violet-500 bg-clip-text text-transparent"> desde un solo lugar</span>
        </h1>

        <p class="animate-fade-up animate-delay-200 mx-auto mt-8 max-w-2xl text-lg leading-relaxed text-zinc-500 dark:text-zinc-400 sm:text-xl">
          Monitoriza, controla y protege tu flota de dispositivos empresariales. Inventario automático, alertas inteligentes y comandos remotos en una plataforma unificada.
        </p>

        <div class="animate-fade-up animate-delay-300 mt-12 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href="https://app.inventowry.com/register" class="group w-full rounded-xl bg-primary-600 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-600/25 transition-all hover:bg-primary-500 hover:shadow-xl hover:shadow-primary-500/30 hover:-translate-y-0.5 sm:w-auto">
            Empieza tu prueba gratuita
            <svg class="ml-2 inline-block size-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
          <a href="#how-it-works" class="w-full rounded-xl border border-zinc-200 bg-white/80 px-8 py-4 text-base font-semibold text-zinc-700 shadow-sm backdrop-blur-sm transition-all hover:bg-white hover:shadow-md hover:-translate-y-0.5 dark:border-zinc-700 dark:bg-zinc-800/80 dark:text-zinc-300 dark:hover:bg-zinc-800 sm:w-auto">
            Ver cómo funciona
          </a>
        </div>

        <p class="animate-fade-up animate-delay-400 mt-5 text-sm text-zinc-400 dark:text-zinc-500">14 días gratis &middot; Sin tarjeta de crédito</p>
      </div>

      <!-- Hero Dashboard Mockup -->
      <div class="animate-fade-up animate-delay-500 relative mx-auto mt-20 max-w-5xl">
        <div class="rounded-2xl border border-zinc-200/80 bg-white p-1.5 shadow-2xl shadow-zinc-900/10 dark:border-zinc-700/50 dark:bg-zinc-800 dark:shadow-black/30">
          <!-- Title bar -->
          <div class="flex items-center gap-2 rounded-t-xl bg-zinc-100 px-4 py-2.5 dark:bg-zinc-700/50">
            <div class="flex gap-1.5">
              <div class="size-2.5 rounded-full bg-red-400"></div>
              <div class="size-2.5 rounded-full bg-amber-400"></div>
              <div class="size-2.5 rounded-full bg-emerald-400"></div>
            </div>
            <div class="mx-auto flex items-center gap-2 rounded-md bg-white/60 px-3 py-1 dark:bg-zinc-600/40">
              <svg class="size-3 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75" /></svg>
              <span class="text-[11px] text-zinc-500 dark:text-zinc-400">app.inventowry.com/dashboard</span>
            </div>
          </div>

          <!-- Dashboard content -->
          <div class="rounded-b-xl bg-zinc-50 p-5 dark:bg-zinc-900/80">
            <!-- Metric cards row -->
            <div class="grid grid-cols-4 gap-3 mb-5">
              <div class="rounded-xl border border-zinc-200/80 bg-white p-3.5 dark:border-zinc-700/50 dark:bg-zinc-800/80">
                <p class="text-[10px] font-medium text-zinc-400 uppercase tracking-wider">Dispositivos</p>
                <p class="mt-1 text-xl font-bold text-zinc-900 dark:text-zinc-100">247</p>
                <div class="mt-1.5 flex items-center gap-1">
                  <span class="text-[10px] font-semibold text-emerald-500">+12%</span>
                  <svg class="size-2.5 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.293 9.707a1 1 0 010-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L11 7.414V15a1 1 0 11-2 0V7.414L6.707 9.707a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg>
                </div>
              </div>
              <div class="rounded-xl border border-zinc-200/80 bg-white p-3.5 dark:border-zinc-700/50 dark:bg-zinc-800/80">
                <p class="text-[10px] font-medium text-zinc-400 uppercase tracking-wider">Online</p>
                <p class="mt-1 text-xl font-bold text-emerald-600 dark:text-emerald-400">231</p>
                <div class="mt-1.5 h-1.5 w-full rounded-full bg-zinc-100 dark:bg-zinc-700">
                  <div class="h-1.5 rounded-full bg-emerald-500" style="width: 93%"></div>
                </div>
              </div>
              <div class="rounded-xl border border-zinc-200/80 bg-white p-3.5 dark:border-zinc-700/50 dark:bg-zinc-800/80">
                <p class="text-[10px] font-medium text-zinc-400 uppercase tracking-wider">Alertas</p>
                <p class="mt-1 text-xl font-bold text-amber-600 dark:text-amber-400">3</p>
                <div class="mt-1.5 flex gap-1">
                  <span class="inline-flex rounded bg-amber-100 px-1.5 py-0.5 text-[9px] font-semibold text-amber-700 dark:bg-amber-900/40 dark:text-amber-400">Warning</span>
                </div>
              </div>
              <div class="rounded-xl border border-zinc-200/80 bg-white p-3.5 dark:border-zinc-700/50 dark:bg-zinc-800/80">
                <p class="text-[10px] font-medium text-zinc-400 uppercase tracking-wider">Uptime</p>
                <p class="mt-1 text-xl font-bold text-primary-600 dark:text-primary-400">99.8%</p>
                <div class="mt-1.5 flex items-center gap-1">
                  <span class="text-[10px] font-semibold text-emerald-500">+0.2%</span>
                </div>
              </div>
            </div>

            <!-- Two columns -->
            <div class="grid grid-cols-5 gap-3">
              <!-- Device list -->
              <div class="col-span-3 rounded-xl border border-zinc-200/80 bg-white dark:border-zinc-700/50 dark:bg-zinc-800/80">
                <div class="border-b border-zinc-100 px-4 py-2.5 dark:border-zinc-700/50">
                  <p class="text-[11px] font-semibold text-zinc-700 dark:text-zinc-300">Dispositivos recientes</p>
                </div>
                <div class="divide-y divide-zinc-100 dark:divide-zinc-700/50">
                  {['srv-prod-01', 'mac-dev-carlos', 'win-mkt-laptop', 'srv-staging-02'].map((name, i) => (
                    <div class="flex items-center justify-between px-4 py-2">
                      <div class="flex items-center gap-2.5">
                        <div class={`size-1.5 rounded-full ${i < 3 ? 'bg-emerald-400' : 'bg-zinc-300 dark:bg-zinc-600'}`}></div>
                        <span class="text-[11px] font-medium text-zinc-700 dark:text-zinc-300">{name}</span>
                      </div>
                      <div class="flex items-center gap-3">
                        <span class="text-[10px] text-zinc-400">{['Linux', 'macOS', 'Windows', 'Linux'][i]}</span>
                        <div class="h-1 w-12 rounded-full bg-zinc-100 dark:bg-zinc-700">
                          <div class={`h-1 rounded-full ${[72, 45, 61, 38][i] > 60 ? 'bg-amber-400' : 'bg-emerald-400'}`} style={`width: ${[72, 45, 61, 38][i]}%`}></div>
                        </div>
                        <span class="text-[10px] tabular-nums text-zinc-400">{[72, 45, 61, 38][i]}%</span>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Platform chart -->
              <div class="col-span-2 rounded-xl border border-zinc-200/80 bg-white p-4 dark:border-zinc-700/50 dark:bg-zinc-800/80">
                <p class="text-[11px] font-semibold text-zinc-700 dark:text-zinc-300 mb-3">Plataformas</p>
                <div class="space-y-3">
                  {[
                    { name: 'Windows', pct: 45, color: 'bg-primary-500' },
                    { name: 'Linux', pct: 35, color: 'bg-emerald-500' },
                    { name: 'macOS', pct: 20, color: 'bg-violet-500' },
                  ].map((p) => (
                    <div>
                      <div class="flex items-center justify-between mb-1">
                        <span class="text-[10px] text-zinc-500 dark:text-zinc-400">{p.name}</span>
                        <span class="text-[10px] font-semibold tabular-nums text-zinc-700 dark:text-zinc-300">{p.pct}%</span>
                      </div>
                      <div class="h-1.5 w-full rounded-full bg-zinc-100 dark:bg-zinc-700">
                        <div class={`h-1.5 rounded-full ${p.color} transition-all`} style={`width: ${p.pct}%`}></div>
                      </div>
                    </div>
                  ))}
                </div>
                <div class="mt-4 flex items-center justify-center gap-4">
                  {[
                    { name: 'Win', color: 'bg-primary-500' },
                    { name: 'Linux', color: 'bg-emerald-500' },
                    { name: 'Mac', color: 'bg-violet-500' },
                  ].map((l) => (
                    <div class="flex items-center gap-1.5">
                      <div class={`size-2 rounded-full ${l.color}`}></div>
                      <span class="text-[9px] text-zinc-400">{l.name}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Glow effect -->
        <div class="absolute -inset-8 -z-10 rounded-3xl bg-gradient-to-r from-primary-500/10 via-violet-500/5 to-cyan-500/10 blur-3xl"></div>
      </div>
    </div>
  </section>

  <!-- Platform badges -->
  <section class="relative py-14 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <p class="mb-8 text-center text-xs font-semibold uppercase tracking-[0.2em] text-zinc-400 dark:text-zinc-500">Compatible con todas las plataformas</p>
      <div class="flex flex-wrap items-center justify-center gap-10 sm:gap-16">
        <div class="group flex items-center gap-3 text-zinc-400 transition-colors hover:text-zinc-600 dark:text-zinc-500 dark:hover:text-zinc-300">
          <svg class="size-7 transition-transform group-hover:scale-110" viewBox="0 0 24 24" fill="currentColor"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/></svg>
          <span class="text-sm font-semibold">Windows</span>
        </div>
